rules_version = '2';

// =====================================================================
//  Firestore-regler för tippningspoolen
//  Firebase Console -> Firestore Database -> Regler -> klistra in -> Publicera
//
//  KRÄVER: Authentication -> Sign-in method -> Anonymous = Enabled
// =====================================================================
//
//  Modell:
//    pools/{poolId}                -> { config, results, joinCode, ownerUid }  (läsbar)
//    pools/{poolId}/secret/host    -> { hostCode }                             (EJ läsbar)
//    pools/{poolId}/claims/{uid}   -> { hostCode }                             (EJ läsbar)
//    pools/{poolId}/tips/{uid}     -> { name, tips, joinCode, updated }
//
//  VÄRDLÅSET
//  Alla loggas in anonymt (osynligt) och får ett uid.
//  Poolens `ownerUid` avgör vem som får ändra turnering och facit.
//
//  Ta över värdskapet (t.ex. ny dator):
//    1. Klienten skriver sin värdkod till claims/{sitt uid}.
//       Ingen kan läsa claims, och man kan bara skriva sin egen.
//    2. Sedan uppdaterar klienten poolen och sätter ownerUid = sitt uid.
//       Regeln godkänner det ENDAST om claims/{uid}.hostCode matchar
//       hemligheten i secret/host.
//  Värdkoden lämnar alltså aldrig databasen och hamnar aldrig i det
//  läsbara pool-dokumentet.
//
//  BORTTAGNING AV SPELARE
//  Ett tips-dokument får raderas av spelaren själv ELLER av poolens ägare
//  (ownerUid) – det senare är vad värdens ×-knapp i Ställning använder för
//  att t.ex. ta bort en dubblettpost.

service cloud.firestore {
  match /databases/{database}/documents {

    match /pools/{poolId} {

      function existing()  { return resource.data; }
      function incoming()  { return request.resource.data; }
      function signedIn()  { return request.auth != null; }
      function isOwner()   { return signedIn() && existing().ownerUid == request.auth.uid; }

      function hostSecret(){ return get(/databases/$(database)/documents/pools/$(poolId)/secret/host).data.hostCode; }
      function hasSecret() { return exists(/databases/$(database)/documents/pools/$(poolId)/secret/host); }
      function myClaim()   { return get(/databases/$(database)/documents/pools/$(poolId)/claims/$(request.auth.uid)).data.hostCode; }
      function hasClaim()  { return exists(/databases/$(database)/documents/pools/$(poolId)/claims/$(request.auth.uid)); }
      function provedHost(){ return signedIn() && hasSecret() && hasClaim() && myClaim() == hostSecret(); }

      allow read: if true;

      allow create: if signedIn()
                    && incoming().ownerUid == request.auth.uid
                    && incoming().joinCode is string
                    && incoming().joinCode.size() >= 4;

      // (1) Ägaren ändrar turnering/facit.  (2) Bevisad värd tar över ownerUid.
      allow update: if
        ( isOwner()
          && incoming().ownerUid == existing().ownerUid
          && incoming().joinCode == existing().joinCode )
        ||
        ( provedHost()
          && incoming().ownerUid == request.auth.uid
          && incoming().joinCode == existing().joinCode );

      allow delete: if false;

      // Hemligheten: skrivs en gång vid skapandet, kan aldrig läsas.
      match /secret/host {
        allow read: if false;
        allow create: if signedIn()
                      && request.resource.data.hostCode is string
                      && request.resource.data.hostCode.size() >= 6;
        allow update, delete: if false;
      }

      // Ditt anspråk på värdskap. Bara du kan skriva ditt, ingen kan läsa.
      match /claims/{uid} {
        allow read: if false;
        allow create, update: if signedIn() && request.auth.uid == uid
                              && request.resource.data.hostCode is string;
        allow delete: if signedIn() && request.auth.uid == uid;
      }

      // Spelarnas tips: ett dokument per uid.
      match /tips/{uid} {
        allow read: if true;
        allow create, update: if signedIn()
                              && request.auth.uid == uid
                              && request.resource.data.joinCode ==
                                 get(/databases/$(database)/documents/pools/$(poolId)).data.joinCode
                              && request.resource.data.name is string
                              && request.resource.data.name.size() > 0
                              && request.resource.data.name.size() <= 40;
        // Spelaren själv ELLER poolens ägare (för att ta bort t.ex. en dubblett).
        allow delete: if signedIn()
                      && ( request.auth.uid == uid
                           || get(/databases/$(database)/documents/pools/$(poolId)).data.ownerUid == request.auth.uid );
      }
    }
  }
}
