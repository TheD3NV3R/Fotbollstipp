rules_version = '2';

// =====================================================================
//  Firestore-regler för tippningspoolen
//  Firebase Console -> Firestore Database -> Regler -> klistra in -> Publicera
//
//  KRÄVER: Authentication -> Sign-in method -> Anonymous = Enabled
// =====================================================================
//
//  Modell:
//    pools/{poolId}                -> { config, results, joinCode, ownerUid }  (läsbar)
//    pools/{poolId}/secret/host    -> { hostCode }                             (EJ läsbar)
//    pools/{poolId}/claims/{uid}   -> { hostCode }                             (EJ läsbar)
//    pools/{poolId}/tips/{uid}     -> { name, tips, joinCode, updated }
//
//  VÄRDLÅSET
//  Alla loggas in anonymt (osynligt) och får ett uid.
//  Poolens `ownerUid` avgör vem som får ändra turnering och facit.
//
//  Ta över värdskapet (t.ex. ny dator):
//    1. Klienten skriver sin värdkod till claims/{sitt uid}.
//       Ingen kan läsa claims, och man kan bara skriva sin egen.
//    2. Sedan uppdaterar klienten poolen och sätter ownerUid = sitt uid.
//       Regeln godkänner det ENDAST om claims/{uid}.hostCode matchar
//       hemligheten i secret/host.
//  Värdkoden lämnar alltså aldrig databasen och hamnar aldrig i det
//  läsbara pool-dokumentet.
//
//  BORTTAGNING AV SPELARE
//  Ett tips-dokument får raderas av spelaren själv ELLER av poolens ägare
//  (ownerUid) – det senare är vad värdens ×-knapp i Ställning använder för
//  att t.ex. ta bort en dubblettpost.

service cloud.firestore {
  match /databases/{database}/documents {

    match /pools/{poolId} {

      function existing()  { return resource.data; }
      function incoming()  { return request.resource.data; }
      function signedIn()  { return request.auth != null; }
      function isOwner()   { return signedIn() && existing().ownerUid == request.auth.uid; }

      function hostSecret(){ return get(/databases/$(database)/documents/pools/$(poolId)/secret/host).data.hostCode; }
      function hasSecret() { return exists(/databases/$(database)/documents/pools/$(poolId)/secret/host); }
      function myClaim()   { return get(/databases/$(database)/documents/pools/$(poolId)/claims/$(request.auth.uid)).data.hostCode; }
      function hasClaim()  { return exists(/databases/$(database)/documents/pools/$(poolId)/claims/$(request.auth.uid)); }
      function provedHost(){ return signedIn() && hasSecret() && hasClaim() && myClaim() == hostSecret(); }

      allow read: if true;

      allow create: if signedIn()
                    && incoming().ownerUid == request.auth.uid
                    && incoming().joinCode is string
                    && incoming().joinCode.size() >= 4;

      // (1) Ägaren ändrar turnering/facit.  (2) Bevisad värd tar över ownerUid.
      allow update: if
        ( isOwner()
          && incoming().ownerUid == existing().ownerUid
          && incoming().joinCode == existing().joinCode )
        ||
        ( provedHost()
          && incoming().ownerUid == request.auth.uid
          && incoming().joinCode == existing().joinCode );

      allow delete: if false;

      // Hemligheten: skrivs en gång vid skapandet, kan aldrig läsas.
      match /secret/host {
        allow read: if false;
        allow create: if signedIn()
                      && request.resource.data.hostCode is string
                      && request.resource.data.hostCode.size() >= 6;
        allow update, delete: if false;
      }

      // Ditt anspråk på värdskap. Bara du kan skriva ditt, ingen kan läsa.
      match /claims/{uid} {
        allow read: if false;
        allow create, update: if signedIn() && request.auth.uid == uid
                              && request.resource.data.hostCode is string;
        allow delete: if signedIn() && request.auth.uid == uid;
      }

      // Spelarnas tips: ett dokument per uid.
      match /tips/{uid} {
        function poolOwner(){ return get(/databases/$(database)/documents/pools/$(poolId)).data.ownerUid; }
        function joinOk(){ return request.resource.data.joinCode ==
                                  get(/databases/$(database)/documents/pools/$(poolId)).data.joinCode; }
        function nameOk(){ return request.resource.data.name is string
                                  && request.resource.data.name.size() > 0
                                  && request.resource.data.name.size() <= 40; }
        // Lås-flaggor (saknas => olåst). locked ligger inuti tips-kartan.
        function lockedGroup(t){ return t.get('locked', {}).get('group', false) == true; }
        function lockedKo(t){    return t.get('locked', {}).get('ko',    false) == true; }
        // Är gruppspels- resp. slutspelsdelen oförändrad mellan gammalt och nytt?
        function groupUnchanged(){ return request.resource.data.tips.get('matches', {}) == resource.data.tips.get('matches', {})
                                       && request.resource.data.tips.get('bonus',   {}) == resource.data.tips.get('bonus',   {}); }
        function koUnchanged(){    return request.resource.data.tips.get('ko', {}) == resource.data.tips.get('ko', {}); }
        // Personlig återkomst: den som raderar har skrivit ett anspråk vars kod
        // matchar den hemliga återkomstkoden för den gamla postens slug.
        function tipClaim(){ return get(/databases/$(database)/documents/pools/$(poolId)/tipclaims/$(request.auth.uid)).data; }
        function tipSecret(s){ return get(/databases/$(database)/documents/pools/$(poolId)/tipsecret/$(s)).data; }
        function resumeProven(){
          return ('slug' in resource.data)
            && exists(/databases/$(database)/documents/pools/$(poolId)/tipclaims/$(request.auth.uid))
            && exists(/databases/$(database)/documents/pools/$(poolId)/tipsecret/$(resource.data.slug))
            && tipClaim().slug == resource.data.slug
            && tipClaim().code == tipSecret(resource.data.slug).code;
        }

        allow read: if true;

        // Skapa sitt eget tips (ingen låsning ännu).
        allow create: if signedIn() && request.auth.uid == uid && joinOk() && nameOk();

        // Uppdatera:
        //  (A) Spelaren själv – men en INLÅST del får inte ändras, och man kan
        //      inte låsa upp sig själv (lås-flaggan måste förbli satt).
        //  (B) Värden (ägaren) – får ändra lås-flaggorna (t.ex. låsa upp så
        //      spelaren kan skicka in igen) men INTE själva tipsinnehållet.
        allow update: if
          ( signedIn() && request.auth.uid == uid && joinOk() && nameOk()
            && ( !lockedGroup(resource.data.tips) || (groupUnchanged() && lockedGroup(request.resource.data.tips)) )
            && ( !lockedKo(resource.data.tips)    || (koUnchanged()    && lockedKo(request.resource.data.tips)) ) )
          ||
          ( signedIn() && poolOwner() == request.auth.uid
            && groupUnchanged() && koUnchanged() );

        // Spelaren själv, poolens ägare (ta bort dubblett), ELLER en spelare som
        // flyttar sin post till en ny enhet med rätt återkomstkod.
        allow delete: if signedIn()
                      && ( request.auth.uid == uid || poolOwner() == request.auth.uid || resumeProven() );
      }

      // Hemlig återkomstkod per spelare (nyckel = slug av namnet). Skrivs en
      // gång vid tippstart, kan aldrig läsas av klienten (bara av reglerna via
      // get()). Poolens ägare (värden) får skriva över koden – så en spelare som
      // glömt sin kan få en ny av värden – men kan fortfarande inte läsa den.
      match /tipsecret/{slug} {
        function poolOwner(){ return get(/databases/$(database)/documents/pools/$(poolId)).data.ownerUid; }
        allow read: if false;
        allow create: if signedIn() && request.resource.data.code is string;
        allow update: if signedIn() && poolOwner() == request.auth.uid
                      && request.resource.data.code is string;
        allow delete: if false;
      }

      // Anspråk vid enhetsbyte: skrivs av den som försöker återuppta, läses bara
      // av reglerna. Bara din egen kan skrivas.
      match /tipclaims/{uid} {
        allow read: if false;
        allow create, update: if signedIn() && request.auth.uid == uid
                              && request.resource.data.code is string;
        allow delete: if signedIn() && request.auth.uid == uid;
      }
    }
  }
}
